{
  "name": "@playlistwizard/api",
  "version": "0.1.1",
  "private": true,
  "types": "./src/exported-types.ts",
  "scripts": {
    "dev": "CLOUDFLARE_INCLUDE_PROCESS_ENV=true dotenv -e ../../apps/www/.env -- wrangler dev",
    "dev:network": "CLOUDFLARE_INCLUDE_PROCESS_ENV=true dotenv -e ../../apps/www/.env -- wrangler dev --ip 0.0.0.0",
    "deploy:dev": "dotenv -e ../../.env -- wrangler deploy --env dev",
    "deploy:production": "dotenv -e ../../.env -- wrangler deploy --env production",
    "test": "vitest run",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/valibot-validator": "0.6.1",
    "@playlistwizard/core": "workspace:*",
    "@playlistwizard/db": "workspace:*",
    "@playlistwizard/playlist-action-job": "workspace:*",
    "@sentry/cloudflare": "10.54.0",
    "better-auth": "1.6.19",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.25",
    "pg": "8.20.0",
    "valibot": "1.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260617.1",
    "@types/node": "20.19.43",
    "@types/pg": "8.20.0",
    "dotenv-cli": "8.0.0",
    "typescript": "5.9.3",
    "wrangler": "4.87.0"
  }
}
