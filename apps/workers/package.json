{
  "name": "@playlistwizard/workers",
  "version": "0.1.0",
  "private": true,
  "types": "./src/exported-types.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- wrangler dev",
    "dev:network": "dotenv -e ../../.env -- wrangler dev --ip 0.0.0.0",
    "deploy:dev": "dotenv -e ../../.env -- wrangler deploy --env dev",
    "deploy:production": "dotenv -e ../../.env -- wrangler deploy --env production",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@playlistwizard/db": "workspace:*",
    "@playlistwizard/playlist-action-job": "workspace:*",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "pg": "^8.16.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260430.1",
    "@types/node": "^20",
    "@types/pg": "^8.11.14",
    "dotenv-cli": "^8.0.0",
    "typescript": "^5",
    "wrangler": "^4.17.0"
  }
}
