{
  "name": "@playlistwizard/ui",
  "version": "0.1.0",
  "description": "Shared UI components and design tokens for PlaylistWizard",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "default": "./dist/components/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "default": "./dist/hooks/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    },
    "./styles/*": "./src/styles/*"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "dev:network": "tsc --watch",
    "test": "vitest run",
    "build": "tsc",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --no-open",
    "storybook:network": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --host 0.0.0.0 --no-open",
    "build-storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build"
  },
  "author": "suzuki3jp",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.512.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.3.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.3.3",
    "typescript": "^5",
    "vite": "^7.1.3",
    "vitest": "^3.1.2"
  }
}
