{
  "name": "@playlistwizard/root",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:network": "pnpm -r --parallel dev:network",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "pnpm build:packages && pnpm -F @playlistwizard/www build",
    "build:vercel": "pnpm -F @playlistwizard/www build:vercel",
    "build:packages": "pnpm -r --filter \"{./packages/*}...\" build",
    "build:api": "pnpm -F @playlistwizard/api typecheck && pnpm -F @playlistwizard/api build:types",
    "build:all": "pnpm build:packages && pnpm build:api && pnpm -F @playlistwizard/www build",
    "migrate": "pnpm -F @playlistwizard/www migrate",
    "generate": "drizzle-kit generate",
    "build:playlist-action-jobs": "pnpm --filter @playlistwizard/playlist-action-jobs... build",
    "packages:new": "node ./scripts/create-package/index.js",
    "release": "changeset publish",
    "cs": "changeset",
    "cm": "node ./scripts/generate-commit-message/index.js",
    "bootstrap": "pnpm install -F \"./packages/**\" && pnpm build:packages && pnpm install",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "prepare": "husky",
    "knip": "knip"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@remix-run/changelog-github": "0.0.5",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.9",
    "clipboardy": "4.0.0",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "husky": "9.1.7",
    "inquirer": "12.11.1",
    "knip": "6.17.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.1.9"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/api": "1.9.1"
    }
  },
  "packageManager": "pnpm@9.15.9"
}
